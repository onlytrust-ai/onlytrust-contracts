# ──────────────────────────────────────────────
# Deployer wallet (owns contracts after deployment)
# ──────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=

# ──────────────────────────────────────────────
# Base Sepolia (testnet, chain ID 84532)
# ──────────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASESCAN_SEPOLIA_API_KEY=

# Testnet USDC (Circle faucet)
# USDC_TOKEN_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# ──────────────────────────────────────────────
# Base Mainnet (chain ID 8453)
# ──────────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
BASESCAN_MAINNET_API_KEY=

# Mainnet USDC (native Circle)
# USDC_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# ──────────────────────────────────────────────
# Platform signer (signs EIP-712 settlement/refund authorizations)
# ──────────────────────────────────────────────
PLATFORM_SIGNER_ADDRESS=

# ──────────────────────────────────────────────
# Fee recipient (receives 1% platform fee at settlement)
# Must be set explicitly — deployment will fail if missing
# ──────────────────────────────────────────────
FEE_RECIPIENT_ADDRESS=

# ──────────────────────────────────────────────
# Deployed contract addresses (populated after deployment)
# ──────────────────────────────────────────────
MANIFEST_REGISTRY_ADDRESS=
ESCROW_ROUTER_ADDRESS=
